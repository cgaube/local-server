{
  "name": "local-server",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "cleanup": "rm -f .*.bun-build",
    "compile": "bun run ts:check && bun build commands/src/main.ts --compress --compile --outfile server && bun run cleanup",
    "ts:check": "tsc --noEmit",
    "prepare": "bun run compile"
  },
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.1002.0",
    "commander": "^14.0.3",
    "consola": "^3.4.2",
    "execa": "^9.6.1",
    "glob": "^13.0.6",
    "inquirer": "^13.3.0",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.3",
    "prettier": "3.8.1",
    "typescript": "^5.9.3"
  }
}
