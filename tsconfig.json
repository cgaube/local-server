{
  "compilerOptions": {
    "target": "esnext",
    "types": ["node"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": "./commands/src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true
  },
  "include": ["commands/src/**/*"],
  "exclude": ["node_modules"]
}
